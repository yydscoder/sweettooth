# SweetTooth Gelato - .gitignore

# ===========================================
# ENVIRONMENT & SECRETS
# ===========================================
.env
.env.local
.env.development
.env.production
*.env
config.js
Sweettooth/config.js

# ===========================================
# DEPENDENCIES
# ===========================================
node_modules/
vendor/
bower_components/

# ===========================================
# BUILD OUTPUTS
# ===========================================
dist/
build/
public/
*.min.css
*.min.js

# ===========================================
# IDE & EDITORS
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================
# LOGS
# ===========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===========================================
# TESTING
# ===========================================
coverage/
.nyc_output/
test-results/

# ===========================================
# TEMPORARY FILES
# ===========================================
tmp/
temp/
.cache/

# ===========================================
# UPLOADS & USER CONTENT
# ===========================================
uploads/
user-content/

# ===========================================
# BACKUPS
# ===========================================
*.bak
*.backup
*.old
